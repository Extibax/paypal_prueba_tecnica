@model PayrollPma.Models.Employee
@{
    ViewData["Title"] = "Editar Empleado";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Editar Empleado</h2>
    <a asp-action="Index" class="btn btn-secondary">Volver a lista</a>
</div>

<form asp-action="Edit" method="post">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Revisa los siguientes campos:</strong>
            <div asp-validation-summary="All" class="mb-0"></div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
        </div>
    }
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Apellido" class="form-label"></label>
        <input asp-for="Apellido" class="form-control" />
        <span asp-validation-for="Apellido" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RatePerHour" class="form-label"></label>
        <input asp-for="RatePerHour" class="form-control" />
        <span asp-validation-for="RatePerHour" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MonthlyHours" class="form-label"></label>
        <input asp-for="MonthlyHours" class="form-control" />
        <span asp-validation-for="MonthlyHours" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>
